#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────────────────────
# VENDORED from pi-harnesses · upstream path: scripts/idc-pi
# Upstream license: MIT © 2026 IndyDevDan — preserved verbatim in
#   runtime/pi/LICENSE-pi-harnesses (no-edit). See repo-root ATTRIBUTIONS.md.
# Vendored into idc-workflow for the Phase-8 Pi runtime (issue #27, unit B1).
# Vendored as reference SOURCE (the launcher's full multi-role orchestration is the
# concern of the Pi adapter, unit B2); upstream source preserved below.
# ─────────────────────────────────────────────────────────────────────────────
set -euo pipefail

resolve_script_path() {
	local source="$1"
	while [[ -L "$source" ]]; do
		local dir target
		dir="$(cd "$(dirname "$source")" && pwd -P)"
		target="$(readlink "$source")"
		if [[ "$target" == /* ]]; then
			source="$target"
		else
			source="$dir/$target"
		fi
	done
	local dir
	dir="$(cd "$(dirname "$source")" && pwd -P)"
	printf '%s/%s\n' "$dir" "$(basename "$source")"
}

SCRIPT_PATH="$(resolve_script_path "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd -P)"
DEFAULT_HARNESS_REPO="$(cd "$SCRIPT_DIR/.." && pwd -P)"
DEFAULT_CMUX_BIN="/Applications/cmux.app/Contents/Resources/bin/cmux"
ALL_ROLES=(think plan sequence ripple build-impl build-review build-finish)
COMS_TOOLS="coms_net_list,coms_net_send,coms_net_get,coms_net_await"
SAFE_ENV_NAMES=(
	HOME USER LOGNAME SHELL PATH PWD TERM TERM_PROGRAM COLORTERM LANG LC_ALL LC_CTYPE TMPDIR
	SSH_AUTH_SOCK XDG_CONFIG_HOME XDG_DATA_HOME XDG_CACHE_HOME
	PI_CODING_AGENT_DIR PI_CODING_AGENT_SESSION_DIR PI_PACKAGE_DIR PI_OFFLINE PI_SKIP_VERSION_CHECK PI_TELEMETRY PI_CACHE_RETENTION
	PI_COMS_NET_HOST PI_COMS_NET_PORT PI_COMS_NET_PUBLIC_URL PI_COMS_NET_SERVER_URL PI_COMS_NET_EXIT_ON_SERVER_SHUTDOWN
	DEV_KNOWLEDGE_HOME DEV_KNOWLEDGE_AUTO_CONTEXT
	NO_COLOR FORCE_COLOR CLICOLOR CLICOLOR_FORCE SSL_CERT_FILE NODE_EXTRA_CA_CERTS
)
SAFE_ENV_PAIRS=()

TARGET_REPO="$(pwd -P)"
HARNESS_REPO="${PI_IDC_HARNESS_REPO:-$DEFAULT_HARNESS_REPO}"
HARNESS_REPO="$(cd "$HARNESS_REPO" 2>/dev/null && pwd -P || printf '%s' "$HARNESS_REPO")"
SCRIPT_SELF="$SCRIPT_PATH"
PROJECT=""

# Optional explicit bearer passthrough — fixes the env -i strip so the documented explicit-token /
# non-loopback hub mode is reachable; empty => the hub auto-generates a loopback token (the default).
AUTH_TOKEN="${PI_COMS_NET_AUTH_TOKEN:-}"

usage() {
	cat <<'USAGE'
IDC Pi Network portable launcher

Usage:
  idc-pi server [--dry-run]
  idc-pi open-all [--dry-run] [pi args...]
  idc-pi open <roles...> [--dry-run]
  idc-pi run <role> [--dry-run] [pi args...]
  idc-pi fleet [roles...] [--dry-run]      # SECURE supervised launch (role-cap enforced)
  idc-pi open-all-cmux [--dry-run]
  idc-pi open-cmux <roles...> [--dry-run]
  idc-pi cmux-doctor
  idc-pi doctor
  idc-pi internal-run-server [--dry-run]
  idc-pi internal-run-role <role> [--dry-run] [pi args...]
  idc-pi help

Accepted roles:
  think plan sequence ripple build-impl build-review build-finish

Environment:
  PI_IDC_HARNESS_REPO        Harness repo path (default: launcher repo)
  PI_IDC_COMS_PROJECT        Override coms-net project
  PI_IDC_SESSION_DIR         Override session directory (default: TARGET_REPO/.pi/agent-sessions)
  PI_IDC_GUARD_MODE          off | warn | block (default: block)
  PI_IDC_RIPPLE_ALLOW_CANONICAL=1 allows Ripple canonical/planning writes
  PI_IDC_CMUX_WORKSPACE_PREFIX Workspace prefix for cmux mode (default: IDC)
  PI_IDC_CMUX_LAYOUT         grid | linear (default: grid)
USAGE
}

derive_project() {
	if [[ -n "${PI_IDC_COMS_PROJECT:-}" ]]; then
		printf '%s\n' "$PI_IDC_COMS_PROJECT"
		return
	fi

	local cfg="$TARGET_REPO/WORKFLOW-config.yaml"
	if [[ -f "$cfg" ]]; then
		local name
		name="$(awk '
			/^[[:space:]]*#/ { next }
			/^[^[:space:]][^:]*:/ { in_project = ($0 ~ /^project:[[:space:]]*$/) }
			in_project && /^[[:space:]]+name:[[:space:]]*/ {
				sub(/^[[:space:]]+name:[[:space:]]*/, "")
				sub(/[[:space:]]+#.*/, "")
				gsub(/^[[:space:]"'"'"']+|[[:space:]"'"'"']+$/, "")
				print
				exit
			}
		' "$cfg")"
		if [[ -n "$name" ]]; then
			printf 'idc-%s\n' "$name"
			return
		fi
	fi

	printf 'idc-%s\n' "$(basename "$TARGET_REPO")"
}

PROJECT="$(derive_project)"
# The project name is interpolated into coms-net state paths
# (~/.pi/coms-net/projects/<project>/), so it must not contain path separators
# or traversal sequences.
if [[ ! "$PROJECT" =~ ^[A-Za-z0-9._-]+$ || "$PROJECT" == *..* ]]; then
	echo "idc-pi: invalid coms project name: '$PROJECT' (allowed: letters, digits, '.', '_', '-')" >&2
	exit 2
fi

main() {
	local cmd="${1:-help}"
	if [[ $# -gt 0 ]]; then shift; fi

	case "$cmd" in
		server) command_server "$@" ;;
		open-all) command_open_all "$@" ;;
		open) command_open "$@" ;;
		run) command_run "$@" ;;
		fleet) command_fleet "$@" ;;
		open-all-cmux) command_open_all_cmux "$@" ;;
		open-cmux) command_open_cmux "$@" ;;
		cmux-doctor) command_cmux_doctor "$@" ;;
		doctor) command_doctor "$@" ;;
		internal-run-server) command_internal_run_server "$@" ;;
		internal-run-role) command_internal_run_role "$@" ;;
		help|-h|--help) usage ;;
		*)
			echo "idc-pi: unknown command: $cmd" >&2
			usage >&2
			exit 2
			;;
	esac
}

command_server() {
	local dry_run=0
	local extra=()
	parse_dry_run dry_run extra "$@"
	local cmd
	if (( ${#extra[@]} )); then
		cmd="$(server_shell_command "${extra[@]}")"
	else
		cmd="$(server_shell_command)"
	fi
	if [[ "$dry_run" == "1" ]]; then
		echo "$cmd"
		return
	fi
	cd "$TARGET_REPO"
	build_safe_env_pairs
	# IDC-LOCAL (codex round-4): standalone/pane hub launch is UNCONFIGURED for role caps — it does
	# NOT inject the master key K (each pane is a separate `env -i` invocation, so a per-pane K can't
	# match the residents'; baking K into the ps-visible pane string would leak it). Role-cap
	# enforcement lives only in the supervised `idc-pi fleet` (one in-memory K). See runtime/pi/SECURITY.md.
	local env_cmd=(env -i "${SAFE_ENV_PAIRS[@]}" "PI_COMS_NET_PROJECT=$PROJECT" "PI_IDC_HARNESS_REPO=$HARNESS_REPO")
	[[ -n "$AUTH_TOKEN" ]] && env_cmd+=("PI_COMS_NET_AUTH_TOKEN=$AUTH_TOKEN")
	if (( ${#extra[@]} )); then
		exec "${env_cmd[@]}" bun "$HARNESS_REPO/scripts/coms-net-server.ts" "${extra[@]}"
	else
		exec "${env_cmd[@]}" bun "$HARNESS_REPO/scripts/coms-net-server.ts"
	fi
}

command_open_all() {
	local dry_run=0
	local extra=()
	parse_dry_run dry_run extra "$@"
	open_cmux_workspace "$dry_run" "${#extra[@]}" "${extra[@]}" "${ALL_ROLES[@]}"
}

command_open() {
	local dry_run=0
	local args=()
	parse_dry_run dry_run args "$@"
	if [[ "${#args[@]}" -eq 0 ]]; then
		echo "idc-pi open requires at least one role" >&2
		exit 2
	fi
	local role
	for role in "${args[@]}"; do validate_role "$role"; done
	open_cmux_workspace "$dry_run" 0 "${args[@]}"
}

# IDC-LOCAL: fail-closed governance gate (issue #28 / codex F4). A long-lived role resident
# loads the compiled governance sidecar (docs/workflow/idc-governance-contract.yaml) once and
# consults it instead of re-reading WORKFLOW.md. Before spawning a resident we prove that the
# sidecar still matches the governed sources on disk (scripts/idc_governance_check.py is
# fail-closed: drift or a missing/malformed sidecar exits non-zero). A failing check BLOCKS the
# launch so no resident boots on governance it cannot prove. Non-IDC repos (no WORKFLOW.md) are
# not gated. Bypass with PI_IDC_GOVERNANCE_CHECK=off (reported on stderr).
governance_preflight() {
	if [[ "${PI_IDC_GOVERNANCE_CHECK:-on}" == "off" ]]; then
		echo "idc-pi: governance preflight SKIPPED (PI_IDC_GOVERNANCE_CHECK=off)" >&2
		return 0
	fi
	[[ -f "$TARGET_REPO/WORKFLOW.md" ]] || return 0  # not an IDC-governed repo
	local plugin_root check
	plugin_root="$(cd "$HARNESS_REPO/../.." 2>/dev/null && pwd -P || true)"
	check="$plugin_root/scripts/idc_governance_check.py"
	if [[ ! -f "$check" ]]; then
		echo "idc-pi: governance preflight: checker not found at $check —" >&2
		echo "        cannot verify governance; set PI_IDC_GOVERNANCE_CHECK=off to bypass." >&2
		exit 3
	fi
	if python3 "$check" --repo "$TARGET_REPO" >&2; then
		echo "idc-pi: governance preflight OK (compiled sidecar matches governed sources)" >&2
		return 0
	fi
	echo "idc-pi: governance preflight FAILED (fail-closed) — recompile the sidecar:" >&2
	echo "        python3 \"$plugin_root/scripts/idc_governance_compile.py\" --repo \"$TARGET_REPO\"" >&2
	echo "        then relaunch (bypass: PI_IDC_GOVERNANCE_CHECK=off)." >&2
	exit 3
}

command_run() {
	local dry_run=0
	local args=()
	parse_dry_run dry_run args "$@"
	if [[ "${#args[@]}" -lt 1 ]]; then
		echo "idc-pi run requires a role" >&2
		exit 2
	fi
	local role="${args[0]}"
	validate_role "$role"
	local extra=("${args[@]:1}")
	local cmd
	if (( ${#extra[@]} )); then
		cmd="$(role_shell_command "$role" "${extra[@]}")"
	else
		cmd="$(role_shell_command "$role")"
	fi
	if [[ "$dry_run" == "1" ]]; then
		echo "$cmd"
		return
	fi
	governance_preflight
	cd "$TARGET_REPO"
	if (( ${#extra[@]} )); then
		build_role_argv "$role" "${extra[@]}"
	else
		build_role_argv "$role"
	fi
	build_safe_env_pairs
	# IDC-LOCAL (codex round-4): standalone/pane resident launch is UNCONFIGURED for role caps (the
	# pane hub above runs without K, so no cap is required). The role capability is injected ONLY by
	# the supervised `idc-pi fleet`, which holds K in memory and direct-spawns residents. (Bearer
	# passthrough kept for the explicit-token / non-loopback case.)
	local env_cmd=(env -i "${SAFE_ENV_PAIRS[@]}" "PI_COMS_NET_PROJECT=$PROJECT" "PI_IDC_HARNESS_REPO=$HARNESS_REPO")
	[[ -n "$AUTH_TOKEN" ]] && env_cmd+=("PI_COMS_NET_AUTH_TOKEN=$AUTH_TOKEN")
	append_idc_runtime_env env_cmd
	exec "${env_cmd[@]}" "${ROLE_CMD[@]}"
}

# IDC-LOCAL (codex round-4 Layer 2): the SECURE supervised launch. ONE process holds the role-cap
# master key K in memory and DIRECT-spawns the hub + every resident as its own child, setting each
# child's environ via a real `env -i` array — so K reaches ONLY the hub and each resident receives
# ONLY its own role's cap. K never touches disk and never appears in a ps-visible command string
# (unlike the cmux/iterm pane mode, which therefore runs unconfigured). The bearer stays on its
# existing 0600 server.secret.json channel (a legitimately-shared secret). See runtime/pi/SECURITY.md.
#
# Test seam: PI_IDC_RESIDENT_BIN overrides the `pi` binary (a fake resident for the smoke) so the
# distribution property — each child gets its cap, none gets K — is verifiable without a real agent.
command_fleet() {
	local dry_run=0
	local roles=()
	parse_dry_run dry_run roles "$@"
	if [[ "${#roles[@]}" -eq 0 ]]; then roles=("${ALL_ROLES[@]}"); fi
	local role
	for role in "${roles[@]}"; do validate_role "$role"; done

	cd "$TARGET_REPO"
	build_safe_env_pairs
	local resident_bin="${PI_IDC_RESIDENT_BIN:-}"

	if [[ "$dry_run" == "1" ]]; then
		echo "# idc-pi fleet (supervised, role-cap enforced) -> bun fleet-supervisor.ts"
		echo "# K + caps are passed to children via execve env maps (never argv); spec is non-secret."
		echo "# hub: coms-net-server.ts (env PI_COMS_NET_ROLE_HMAC_KEY=<in-memory K>)"
		for role in "${roles[@]}"; do
			echo "# resident $role: ${resident_bin:-pi} … (env PI_COMS_NET_ROLE_CAP=<HMAC(K,$role)>)"
		done
		return
	fi

	# Gate the whole fleet on governance drift, fail-closed, BEFORE anything spawns (same gate as
	# `idc-pi run`; codex round-5 finding 2 — the fleet must not bypass it).
	governance_preflight

	# The hub master key K — used ONLY here (the supervised fleet). Pinned from the env if a wrapper
	# set it, else generated in memory. K never touches disk and never enters an argv (it flows to
	# the supervisor as a shell env assignment below; the supervisor computes caps in-memory).
	local ROLE_HMAC_KEY="${PI_COMS_NET_ROLE_HMAC_KEY:-}"
	if [[ -z "$ROLE_HMAC_KEY" ]]; then
		ROLE_HMAC_KEY="$(openssl rand -hex 32 2>/dev/null || head -c 32 /dev/urandom | od -An -tx1 | tr -d ' \n')"
	fi

	# Hand the SECRET-FREE spec (each child's argv + base env) to the supervisor via NUL-delimited
	# files; the supervisor (bun) computes the caps in memory and sets each child's env via execve
	# maps. K + the optional explicit bearer flow to the supervisor as shell env ASSIGNMENTS (execve
	# env, NOT argv) — so neither K nor any cap ever appears in a ps-visible command string.
	local spec; spec="$(mktemp -d)"
	local base=("${SAFE_ENV_PAIRS[@]}" "PI_COMS_NET_PROJECT=$PROJECT" "PI_IDC_HARNESS_REPO=$HARNESS_REPO")
	printf '%s\0' "${base[@]}" > "$spec/hub.env"
	printf '%s\0' bun "$HARNESS_REPO/scripts/coms-net-server.ts" > "$spec/hub.argv"
	printf '%s\0' "${roles[@]}" > "$spec/roles"
	for role in "${roles[@]}"; do
		build_role_argv "$role"
		local renv=("${SAFE_ENV_PAIRS[@]}" "PI_COMS_NET_PROJECT=$PROJECT" "PI_IDC_HARNESS_REPO=$HARNESS_REPO")
		append_idc_runtime_env renv
		printf '%s\0' "${renv[@]}" > "$spec/$role.env"
		if [[ -n "$resident_bin" ]]; then
			printf '%s\0' "$resident_bin" "${ROLE_CMD[@]:1}" > "$spec/$role.argv"
		else
			printf '%s\0' "${ROLE_CMD[@]}" > "$spec/$role.argv"
		fi
	done

	if [[ -n "$AUTH_TOKEN" ]]; then
		PI_COMS_NET_ROLE_HMAC_KEY="$ROLE_HMAC_KEY" PI_COMS_NET_AUTH_TOKEN="$AUTH_TOKEN" PI_IDC_FLEET_SPEC="$spec" \
			exec bun "$HARNESS_REPO/scripts/fleet-supervisor.ts"
	else
		PI_COMS_NET_ROLE_HMAC_KEY="$ROLE_HMAC_KEY" PI_IDC_FLEET_SPEC="$spec" \
			exec bun "$HARNESS_REPO/scripts/fleet-supervisor.ts"
	fi
}

command_open_all_cmux() {
	local dry_run=0
	local args=()
	parse_dry_run dry_run args "$@"
	if (( ${#args[@]} )); then
		echo "idc-pi open-all-cmux only accepts --dry-run" >&2
		exit 2
	fi
	open_cmux_workspace "$dry_run" 0 "${ALL_ROLES[@]}"
}

command_open_cmux() {
	local dry_run=0
	local args=()
	parse_dry_run dry_run args "$@"
	if [[ "${#args[@]}" -eq 0 ]]; then
		echo "idc-pi open-cmux requires at least one role" >&2
		exit 2
	fi
	local role
	for role in "${args[@]}"; do validate_role "$role"; done
	open_cmux_workspace "$dry_run" 0 "${args[@]}"
}

command_internal_run_server() {
	command_server "$@"
}

command_internal_run_role() {
	local dry_run=0
	local args=()
	parse_dry_run dry_run args "$@"
	if [[ "${#args[@]}" -lt 1 ]]; then
		echo "idc-pi internal-run-role requires a role" >&2
		exit 2
	fi
	local role="${args[0]}"
	validate_role "$role"
	local extra=("${args[@]:1}")
	if [[ "$dry_run" == "1" ]]; then
		command_run "$role" --dry-run "${extra[@]}"
		return
	fi
	wait_for_server
	command_run "$role" "${extra[@]}"
}

command_cmux_doctor() {
	if [[ $# -gt 0 ]]; then
		echo "idc-pi cmux-doctor does not accept arguments" >&2
		exit 2
	fi

	local cmux=""
	local mode=""
	local likely="no"
	local reason="cmux binary not found"
	if cmux="$(cmux_binary 2>/dev/null)"; then
		mode="$(cmux_access_mode "$cmux" 2>/dev/null || true)"
		if inside_cmux; then
			likely="yes"
			reason="running inside cmux"
		elif [[ "$mode" == "cmuxOnly" ]]; then
			likely="no"
			reason="access_mode is cmuxOnly and this shell is outside cmux"
		elif [[ -n "$mode" ]]; then
			likely="yes"
			reason="access_mode is $mode"
		else
			likely="unknown"
			reason="could not read cmux capabilities"
		fi
	fi

	cat <<EOF
IDC Pi cmux doctor
  target repo:       $TARGET_REPO
  harness repo:      $HARNESS_REPO
  project:           $PROJECT
  cmux path:         ${cmux:-not found}
  cmux version:      $(cmux_version_string "$cmux")
  access_mode:       ${mode:-unknown}
  CMUX_WORKSPACE_ID: ${CMUX_WORKSPACE_ID:-unset}
  CMUX_SURFACE_ID:   ${CMUX_SURFACE_ID:-unset}
  inside cmux:       $(inside_cmux && echo yes || echo no)
  can create likely: $likely ($reason)
EOF
}

command_doctor() {
	if [[ $# -gt 0 ]]; then
		echo "idc-pi doctor does not accept arguments" >&2
		exit 2
	fi

	echo "IDC Pi doctor"
	echo "  target repo:  $TARGET_REPO"
	echo "  harness repo: $HARNESS_REPO"
	echo "  project:      $PROJECT"
	echo "  session dir:  $(display_session_dir)"
	echo ""
	echo "Target IDC files:"
	print_found "$TARGET_REPO/WORKFLOW.md"
	print_found "$TARGET_REPO/WORKFLOW-config.yaml"
	print_found "$TARGET_REPO/docs/workflow/tracker-config.yaml"
	echo ""
	echo "Harness assets:"
	print_found "$HARNESS_REPO/extensions/coms-net.ts"
	print_found "$HARNESS_REPO/extensions/minimal.ts"
	print_found "$HARNESS_REPO/extensions/theme-cycler.ts"
	print_found "$HARNESS_REPO/extensions/idc-role-harness.ts"
	print_found "$HARNESS_REPO/scripts/coms-net-server.ts"
	local role
	for role in "${ALL_ROLES[@]}"; do print_found "$(role_prompt "$role")"; done
	echo ""
	if command -v cmux >/dev/null 2>&1; then
		echo "cmux: found at $(command -v cmux)"
	else
		echo "cmux: not found"
	fi
	echo ""
	if server_running; then
		echo "coms server: running ($(server_json_path))"
	else
		echo "coms server: not running for project $PROJECT"
	fi
	echo ""
	echo "Role launch command previews:"
	for role in "${ALL_ROLES[@]}"; do
		echo "-- $role"
		role_shell_command "$role"
	done
}

parse_dry_run() {
	local __dry_var="$1"
	local __array_var="$2"
	shift 2
	local dry=0
	local out=()
	local arg
	for arg in "$@"; do
		if [[ "$arg" == "--dry-run" ]]; then
			dry=1
		else
			out+=("$arg")
		fi
	done
	eval "$__dry_var=$dry"
	# Populate the caller's array via a single printf %q round-trip. %q escapes
	# every shell metacharacter, so the eval cannot re-evaluate command
	# substitutions, backticks, or parameter expansions in user-supplied args.
	if (( ${#out[@]} )); then
		eval "$__array_var=( $(printf '%q ' "${out[@]}") )"
	else
		eval "$__array_var=()"
	fi
}

validate_role() {
	case "$1" in
		think|plan|sequence|ripple|build-impl|build-review|build-finish) ;;
		*)
			echo "idc-pi: unknown role: $1" >&2
			echo "accepted roles: ${ALL_ROLES[*]}" >&2
			exit 2
			;;
	esac
}

open_cmux_workspace() {
	local dry_run="$1"
	local extra_count="$2"
	shift 2
	local role_extra=()
	if (( extra_count > 0 )); then
		role_extra=("${@:1:extra_count}")
		shift "$extra_count"
	fi
	local roles=("$@")
	local cmux="cmux" workspace_name description layout fallback_reason
	workspace_name="$(cmux_workspace_name)"
	description="target: $TARGET_REPO | coms project: $PROJECT"
	layout="$(cmux_layout_json "${#role_extra[@]}" "${role_extra[@]}" "${roles[@]}")"

	CMUX_CMD=(
		"$cmux"
		new-workspace
		--name "$workspace_name"
		--description "$description"
		--cwd "$TARGET_REPO"
		--layout "$layout"
	)

	if [[ "$dry_run" == "1" ]]; then
		echo "# would run: cmux new-workspace"
		echo "# workspace: $workspace_name"
		echo "# cwd: $TARGET_REPO"
		printf '# args: --name %s --cwd %s\n' "$(shell_quote "$workspace_name")" "$(shell_quote "$TARGET_REPO")"
		echo "# pane: coms internal-run-server"
		local role extra
		for role in "${roles[@]}"; do
			printf '# pane: %s internal-run-role %s' "$role" "$(shell_quote "$role")"
			for extra in "${role_extra[@]}"; do printf ' %s' "$(shell_quote "$extra")"; done
			printf '\n'
		done
		join_shell "${CMUX_CMD[@]}"
		printf '\n'
		return
	fi

	if ! cmux="$(cmux_binary 2>/dev/null)"; then
		fallback_reason="cmux not found on PATH or at $DEFAULT_CMUX_BIN"
	else
		CMUX_CMD[0]="$cmux"
		if fallback_reason="$(cmux_unavailable_reason "$cmux")"; then
			:
		else
			fallback_reason=""
		fi
		if [[ -z "$fallback_reason" ]]; then
			echo "Opening cmux workspace for IDC roles: ${roles[*]}"
			if "${CMUX_CMD[@]}"; then
				return
			fi
			fallback_reason="cmux new-workspace failed"
		fi
	fi

	echo "cmux workspace unavailable; falling back to iTerm2${fallback_reason:+ ($fallback_reason)}"
	open_iterm_workspace "${#role_extra[@]}" "${role_extra[@]}" "${roles[@]}"
}

cmux_workspace_name() {
	printf '%s: %s\n' "${PI_IDC_CMUX_WORKSPACE_PREFIX:-IDC}" "$(basename "$TARGET_REPO")"
}

cmux_layout_json() {
	local extra_count="$1"
	shift
	local role_extra=()
	if (( extra_count > 0 )); then
		role_extra=("${@:1:extra_count}")
		shift "$extra_count"
	fi
	local roles=("$@")
	local args=()
	args+=("coms" "$(cmux_pane_command coms internal-run-server)")
	local role
	for role in "${roles[@]}"; do
		args+=("$role" "$(cmux_pane_command "$role" internal-run-role "$role" "${role_extra[@]}")")
	done

	bun -e '
const [layoutMode, ...raw] = process.argv.slice(1);
if (raw.length % 2) throw new Error("cmux layout expects label/command pairs");
const items = [];
for (let i = 0; i < raw.length; i += 2) items.push([raw[i], raw[i + 1]]);
const pane = ([label, command]) => ({ pane: { surfaces: [{ type: "terminal", command }] } });
const nodes = items.map(pane);
const combine = (parts, direction) => {
  if (parts.length === 1) return parts[0];
  const mid = Math.ceil(parts.length / 2);
  return {
    direction,
    split: Number((mid / parts.length).toFixed(4)),
    children: [combine(parts.slice(0, mid), direction), combine(parts.slice(mid), direction)],
  };
};
let root;
if (nodes.length <= 2 || layoutMode === "linear") {
  root = combine(nodes, "horizontal");
} else {
  const cols = nodes.length >= 7 ? 4 : Math.ceil(Math.sqrt(nodes.length));
  const rows = [];
  for (let i = 0; i < nodes.length; i += cols) rows.push(nodes.slice(i, i + cols));
  root = combine(rows.map((row) => combine(row, "horizontal")), "vertical");
}
console.log(JSON.stringify(root));
' "${PI_IDC_CMUX_LAYOUT:-grid}" "${args[@]}"
}

cmux_pane_command() {
	local label="$1"
	local internal_cmd="$2"
	shift 2
	local title="IDC $label"
	local banner="IDC $label — $TARGET_REPO"
	# cmux launches each pane in a fresh shell with app-level environment. Start
	# the internal launcher under env -i so CMUX/Ghostty/ambient API keys never
	# become part of the role/server process environment or Terminal hover text.
	printf 'printf %s; echo %s; exec ' \
		"$(shell_quote "\\033]0;$title\\007")" \
		"$(shell_quote "$banner")"
	print_sanitized_env_prefix
	printf ' PI_IDC_COMS_PROJECT=%s PI_IDC_HARNESS_REPO=%s' \
		"$(shell_quote "$PROJECT")" \
		"$(shell_quote "$HARNESS_REPO")"
	print_idc_runtime_env_shell
	printf ' %s %s' \
		"$(shell_quote "$SCRIPT_SELF")" \
		"$(shell_quote "$internal_cmd")"
	local arg
	for arg in "$@"; do
		printf ' %s' "$(shell_quote "$arg")"
	done
}

cmux_binary() {
	if command -v cmux >/dev/null 2>&1; then
		command -v cmux
		return 0
	fi
	if [[ -x "$DEFAULT_CMUX_BIN" ]]; then
		printf '%s\n' "$DEFAULT_CMUX_BIN"
		return 0
	fi
	echo "idc-pi: cmux not found on PATH or at $DEFAULT_CMUX_BIN" >&2
	return 1
}

cmux_access_mode() {
	local cmux="$1"
	"$cmux" capabilities 2>/dev/null | awk -F'"' '/access_mode/ { print $4; exit }'
}

cmux_version_string() {
	local cmux="$1"
	if [[ -z "$cmux" ]]; then
		printf 'not available'
		return
	fi
	"$cmux" version 2>/dev/null | head -1 || printf 'unknown'
}

inside_cmux() {
	[[ -n "${CMUX_WORKSPACE_ID:-}" && -n "${CMUX_SURFACE_ID:-}" ]]
}

cmux_unavailable_reason() {
	local cmux="$1"
	local mode
	if inside_cmux; then return 1; fi
	mode="$(cmux_access_mode "$cmux" 2>/dev/null || true)"
	if [[ "$mode" == "cmuxOnly" ]]; then
		echo "cmux capabilities reports cmuxOnly outside cmux"
		return 0
	fi
	if [[ -z "$mode" ]]; then
		echo "cmux capabilities returned no access_mode"
		return 0
	fi
	return 1
}

open_iterm_workspace() {
	local extra_count="$1"
	shift
	local role_extra=()
	if (( extra_count > 0 )); then
		role_extra=("${@:1:extra_count}")
		shift "$extra_count"
	fi
	local roles=("$@")
	local workspace_name
	workspace_name="$(cmux_workspace_name)"
	local osascript_args=("$workspace_name coms" "$(cmux_pane_command coms internal-run-server)")
	local role
	for role in "${roles[@]}"; do
		osascript_args+=("$workspace_name $role" "$(cmux_pane_command "$role" internal-run-role "$role" "${role_extra[@]}")")
	done
	osascript \
		-e 'on run argv' \
		-e 'tell application "iTerm2"' \
		-e 'activate' \
		-e 'set w to (create window with default profile)' \
		-e 'set i to 1' \
		-e 'repeat while i is less than or equal to (count of argv)' \
		-e 'set shellCommand to item (i + 1) of argv' \
		-e 'if i = 1 then' \
		-e 'tell current session of w' \
		-e 'write text shellCommand' \
		-e 'end tell' \
		-e 'else' \
		-e 'tell w' \
		-e 'create tab with default profile' \
		-e 'tell current session' \
		-e 'write text shellCommand' \
		-e 'end tell' \
		-e 'end tell' \
		-e 'end if' \
		-e 'set i to i + 2' \
		-e 'end repeat' \
		-e 'end tell' \
		-e 'end run' \
		"${osascript_args[@]}" >/dev/null
}

build_role_argv() {
	local role="$1"
	shift || true
	local session_dir="${PI_IDC_SESSION_DIR:-$TARGET_REPO/.pi/agent-sessions}"
	local guard_mode="${PI_IDC_GUARD_MODE:-block}"
	local tools model thinking provider purpose color prompt skill

	prompt="$(role_prompt "$role")"
	purpose="$(role_purpose "$role")"
	color="$(role_color "$role")"
	skill="$(role_skill "$role")"
	tools="$(role_tools "$role")"
	model="$(role_model "$role")"
	thinking="$(role_thinking "$role")"

	ROLE_CMD=(
		pi
		-e "$HARNESS_REPO/extensions/coms-net.ts"
		-e "$HARNESS_REPO/extensions/minimal.ts"
		-e "$HARNESS_REPO/extensions/theme-cycler.ts"
		-e "$HARNESS_REPO/extensions/idc-role-harness.ts"
		--session-dir "$session_dir"
		--session-id "idc-$role"
		--append-system-prompt "$prompt"
		--skill "/Users/jeremy/.agents/skills/idc-workflow"
		--skill "$skill"
		--project "$PROJECT"
		--name "$role"
		--purpose "$purpose"
		--color "$color"
	)

	if [[ "$role" == "build-review" ]]; then
		provider="${PI_IDC_BUILD_REVIEW_PROVIDER:-openai}"
		ROLE_CMD+=(--provider "$provider")
	fi

	ROLE_CMD+=(
		--model "$model"
		--thinking "$thinking"
		--tools "$tools"
		--idc-role "$role"
		--idc-guard-mode "$guard_mode"
	)

	ROLE_CMD+=("$@")
}

role_shell_command() {
	local role="$1"
	shift || true
	build_role_argv "$role" "$@"
	printf 'cd %s && exec ' "$(shell_quote "$TARGET_REPO")"
	print_sanitized_env_prefix
	printf ' PI_COMS_NET_PROJECT=%s PI_IDC_HARNESS_REPO=%s' \
		"$(shell_quote "$PROJECT")" \
		"$(shell_quote "$HARNESS_REPO")"
	print_idc_runtime_env_shell
	printf ' '
	join_shell "${ROLE_CMD[@]}"
	printf '\n'
}

server_shell_command() {
	printf 'cd %s && exec ' "$(shell_quote "$TARGET_REPO")"
	print_sanitized_env_prefix
	printf ' PI_COMS_NET_PROJECT=%s PI_IDC_HARNESS_REPO=%s ' \
		"$(shell_quote "$PROJECT")" \
		"$(shell_quote "$HARNESS_REPO")"
	join_shell bun "$HARNESS_REPO/scripts/coms-net-server.ts" "$@"
	printf '\n'
}

wait_for_server() {
	local _
	for _ in $(seq 1 20); do
		if server_running; then return 0; fi
		sleep 0.5
	done
	echo "idc-pi: warning: coms-net server did not become healthy within 10s" >&2
}

server_json_path() {
	printf '%s/.pi/coms-net/projects/%s/server.json\n' "$HOME" "$PROJECT"
}

server_running() {
	local json
	json="$(server_json_path)"
	[[ -f "$json" ]] || return 1
	local pid url
	pid="$(json_get "$json" pid)"
	url="$(json_get "$json" local_url)"
	if [[ -n "$pid" ]] && ! kill -0 "$pid" >/dev/null 2>&1; then return 1; fi
	[[ -n "$url" ]] || return 1
	curl -fsS --max-time 1 "$url/health" >/dev/null 2>&1
}

json_get() {
	local file="$1"
	local key="$2"
	sed -nE "s/.*\"$key\"[[:space:]]*:[[:space:]]*\"([^\"]*)\".*/\1/p; s/.*\"$key\"[[:space:]]*:[[:space:]]*([0-9]+).*/\1/p" "$file" | head -1
}

role_prompt() {
	case "$1" in
		think) printf '%s/.pi/agents/idc/think.md\n' "$HARNESS_REPO" ;;
		plan) printf '%s/.pi/agents/idc/plan.md\n' "$HARNESS_REPO" ;;
		sequence) printf '%s/.pi/agents/idc/sequence.md\n' "$HARNESS_REPO" ;;
		ripple) printf '%s/.pi/agents/idc/ripple.md\n' "$HARNESS_REPO" ;;
		build-impl) printf '%s/.pi/agents/idc/build-implementer.md\n' "$HARNESS_REPO" ;;
		build-review) printf '%s/.pi/agents/idc/build-reviewer.md\n' "$HARNESS_REPO" ;;
		build-finish) printf '%s/.pi/agents/idc/build-finisher.md\n' "$HARNESS_REPO" ;;
	esac
}

role_skill() {
	case "$1" in
		think) echo "/Users/jeremy/.agents/skills/codex-idc-think" ;;
		plan) echo "/Users/jeremy/.agents/skills/codex-idc-plan" ;;
		sequence) echo "/Users/jeremy/.agents/skills/codex-idc-sequence" ;;
		ripple) echo "/Users/jeremy/.agents/skills/codex-idc-ripple" ;;
		build-impl|build-review|build-finish) echo "/Users/jeremy/.agents/skills/codex-idc-build" ;;
	esac
}

role_purpose() {
	case "$1" in
		think) echo "IDC Think: considerations only" ;;
		plan) echo "IDC Plan: canonical planning" ;;
		sequence) echo "IDC Sequence: tracker wave admission" ;;
		ripple) echo "IDC Ripple: drift and change orders" ;;
		build-impl) echo "IDC Build: implementation" ;;
		build-review) echo "IDC Build: read-only review" ;;
		build-finish) echo "IDC Build: finish and cleanup" ;;
	esac
}

role_color() {
	case "$1" in
		think) echo "#72F1B8" ;;
		plan) echo "#36F9F6" ;;
		sequence) echo "#FEDE5D" ;;
		ripple) echo "#C792EA" ;;
		build-impl) echo "#FF8B39" ;;
		build-review) echo "#FF7EDB" ;;
		build-finish) echo "#4D9DE0" ;;
	esac
}

role_tools() {
	if [[ "$1" == "build-review" ]]; then
		printf 'read,bash,grep,find,ls,%s\n' "$COMS_TOOLS"
	else
		printf 'read,write,edit,bash,grep,find,ls,%s\n' "$COMS_TOOLS"
	fi
}

role_model() {
	case "$1" in
		think) echo "${PI_IDC_THINK_MODEL:-claude-opus-4-7}" ;;
		plan) echo "${PI_IDC_PLAN_MODEL:-claude-opus-4-7}" ;;
		sequence) echo "${PI_IDC_SEQUENCE_MODEL:-deepseek/deepseek-v4-pro}" ;;
		ripple) echo "${PI_IDC_RIPPLE_MODEL:-deepseek/deepseek-v4-pro}" ;;
		build-impl) echo "${PI_IDC_BUILD_IMPL_MODEL:-claude-opus-4-7}" ;;
		build-review) echo "${PI_IDC_BUILD_REVIEW_MODEL:-gpt-5.5}" ;;
		build-finish) echo "${PI_IDC_BUILD_FINISH_MODEL:-claude-opus-4-7}" ;;
	esac
}

role_thinking() {
	case "$1" in
		think) echo "${PI_IDC_THINK_THINKING:-high}" ;;
		plan) echo "${PI_IDC_PLAN_THINKING:-high}" ;;
		sequence) echo "${PI_IDC_SEQUENCE_THINKING:-high}" ;;
		ripple) echo "${PI_IDC_RIPPLE_THINKING:-high}" ;;
		build-impl) echo "${PI_IDC_BUILD_IMPL_THINKING:-high}" ;;
		build-review) echo "${PI_IDC_BUILD_REVIEW_THINKING:-high}" ;;
		build-finish) echo "${PI_IDC_BUILD_FINISH_THINKING:-high}" ;;
	esac
}

display_session_dir() {
	local dir="${PI_IDC_SESSION_DIR:-$TARGET_REPO/.pi/agent-sessions}"
	if [[ "$dir" = /* ]]; then echo "$dir"; else echo "$TARGET_REPO/$dir"; fi
}

print_found() {
	if [[ -e "$1" ]]; then
		echo "  found   $1"
	else
		echo "  missing $1"
	fi
}

is_safe_env_name() {
	local name="$1" safe
	for safe in "${SAFE_ENV_NAMES[@]}"; do
		if [[ "$name" == "$safe" ]]; then return 0; fi
	done
	[[ "$name" == LC_* ]]
}

build_safe_env_pairs() {
	SAFE_ENV_PAIRS=()
	local name value
	while IFS= read -r name; do
		if [[ "$name" == "PWD" ]]; then continue; fi
		if ! is_safe_env_name "$name"; then continue; fi
		if [[ -z "${!name+x}" ]]; then continue; fi
		value="${!name}"
		SAFE_ENV_PAIRS+=("$name=$value")
	done < <(compgen -e | sort)
	SAFE_ENV_PAIRS+=("PWD=$TARGET_REPO")
}

print_sanitized_env_prefix() {
	build_safe_env_pairs
	printf 'env -i'
	local pair
	for pair in "${SAFE_ENV_PAIRS[@]}"; do
		printf ' %s' "$(shell_quote "$pair")"
	done
}

print_idc_runtime_env_shell() {
	local name
	for name in PI_IDC_RIPPLE_ALLOW_CANONICAL PI_IDC_LIVE_OP_ROLES PI_IDC_ALLOW_LIVE_OPS; do
		if [[ -n "${!name+x}" ]]; then
			printf ' %s=%s' "$name" "$(shell_quote "${!name}")"
		fi
	done
}

append_idc_runtime_env() {
	local array_name="$1"
	local name quoted_value
	for name in PI_IDC_RIPPLE_ALLOW_CANONICAL PI_IDC_LIVE_OP_ROLES PI_IDC_ALLOW_LIVE_OPS; do
		if [[ -n "${!name+x}" ]]; then
			printf -v quoted_value '%q' "$name=${!name}"
			eval "$array_name+=( $quoted_value )"
		fi
	done
}

join_shell() {
	local first=1
	local arg
	for arg in "$@"; do
		if [[ "$first" == "1" ]]; then first=0; else printf ' '; fi
		shell_quote "$arg"
	done
}

shell_quote() {
	local s="$1"
	printf "'%s'" "$(printf '%s' "$s" | sed "s/'/'\\\\''/g")"
}

main "$@"
